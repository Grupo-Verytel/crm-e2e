# ============================================================
#  CRM E2E — Variables de entorno del BACKEND
#  Ubicacion: crm-e2e/backend/.env   (renombra este archivo a ".env")
#  NUNCA se sube a Git (ya esta en .gitignore).
# ============================================================

# ---- Aplicacion ----
NODE_ENV=development
PORT=3000
# Origen permitido para CORS (la URL donde corre tu frontend Vite)
CORS_ORIGIN=http://localhost:5173

# ---- Base de datos MySQL ----
# Ajusta usuario, password y nombre de la base a tu instalacion local de MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=tu_password_de_mysql
DB_DATABASE=crm_e2e
DB_DIALECT=mysql
# En desarrollo puedes dejar logs de SQL en true para ver las consultas
DB_LOGGING=false

# ---- Autenticacion (JWT) ----
# Secretos generados al azar (seguros). Para produccion, genera otros distintos.
JWT_SECRET=cd0db2e5c325bee50557fd34766e155f47399223a45c31e91c9fbd045a4301db
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=7c9f7f0846d6f267270dafa46e89c51eae21b3be4e6e2ca429c1f73186d2290b
JWT_REFRESH_EXPIRES_IN=7d

# ---- Auditoria / zona horaria ----
# UUID del actor de sistema (debe coincidir con el seed system user)
AUDIT_SYSTEM_USER_ID=00000000-0000-4000-8000-000000000001
# Los timestamps se guardan en UTC (regla del Blueprint). No cambiar salvo decision de arquitectura.
TZ=UTC

# ---- Usuario Admin inicial (solo para seed local) ----
ADMIN_INITIAL_EMAIL=admin@verytel.local
ADMIN_INITIAL_PASSWORD=ChangeMe123!